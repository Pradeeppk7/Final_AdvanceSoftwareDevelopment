<?xml version="1.0" encoding="UTF-8"?>
<persistence xmlns="https://jakarta.ee/xml/ns/persistence"
             xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
             xsi:schemaLocation="https://jakarta.ee/xml/ns/persistence
             https://jakarta.ee/xml/ns/persistence/persistence_3_0.xsd"
             version="3.0">

    <persistence-unit name="HRPU" transaction-type="JTA">

        <jta-data-source>jdbc/HrDS</jta-data-source>

        <class>io.github.pradeeppk7.hrdirectoryfinal.entity.Department</class>
        <class>io.github.pradeeppk7.hrdirectoryfinal.entity.Employee</class>

        <properties>
            <property name="jakarta.persistence.schema-generation.database.action" value="none"/>
        </properties>

    </persistence-unit>

</persistence>